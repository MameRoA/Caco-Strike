// checks for collision against ground and other solid actors
// From an old version of nashmove.pk3
//unused.

Actor Nash_FloorCheck
{
	Radius 16
	Height 4
	+SOLID
	States
	{
		Spawn:
			TNT1 A 1
			Stop
	}
}

Actor HeadHit : CustomInventory
{
Inventory.PickupSound "Headshot"
States
{
Pickup:
TNT1 A 0 A_JumpIfInventory("BasicArmor",1,"Helmet")
TNT1 A 0 A_PlaySound("headshot",CHAN_VOICE)
Stop
Helmet:
TNT1 A 0 A_PlaySound("helmet",CHAN_VOICE)
Stop
}
}
Actor IsCrouching : Inventory
{
Inventory.MaxAmount 1
}
Actor IsFiring : Inventory
{
Inventory.MaxAmount 1
}
Actor NoBuy : Inventory
{
Inventory.MaxAmount 1
}
Actor MoneyGive : CustomInventory
{
States
{
Pickup:
TNT1 A 0 ACS_NamedExecuteWithResult("CS_PlayerGiveMoney")
Stop
}
}